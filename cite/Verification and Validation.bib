@article{kamm_ecient_nodate,
	title = {On Eﬃcient Generation of Numerically Robust Sedov Solutions},
	abstract = {We describe the eﬃcient generation of robust numerical solutions for a Sedov blast wave propagating through a polytropic gas characterized by a density gradient ρ=ρ0 r−ω. We discuss all possible families of real solutions, in all common geometries, and address all six removable singularities. The nature of the solutions changes dramatically as ω and the adiabatic index γ vary. Implementation of Sedov solutions requires extended precision arithmetic near the origin to avoid running out of signiﬁcant ﬁgures. We suggest several new problem deﬁnitions for verifying hydrodynamic codes, and oﬀer public domain modules to generate the necessary closed-form solutions.},
	publisher = {Los Alamos National Laboratory},
	author = {Kamm, James R and Timmes, F X},
	langid = {english},
	file = {PDF:/Users/speedyturtle/Zotero/storage/8DR24LF2/Kamm and Timmes - On Eﬃcient Generation of Numerically Robust Sedov Solutions.pdf:application/pdf},
}

@misc{noauthor_equations_1953,
