@book{wilcox_turbulence_2006,
	edition = {3rd},
	title = {Turbulence Modeling for {CFD}},
	isbn = {978-1-928729-08-2},
	series = {Turbulence Modeling for {CFD}},
	abstract = {The book revolves around the fact that turbulence modeling is one of three key elements in {CFD}. Very precise mathematical theories have evolved for the other two, viz., grid generation and algorithm development. By its nature, i.e., creating a mathematical model that approximates the physical behavior of turbulent flows, far less precision has been achieved in turbulence modeling. This text addresses the problem of selecting/devising such models. The fundamental premise is, in the spirit of G. I. Taylor, an ideal model should introduce the minimum amount of complexity while capturing the essence of the relevant physics.},
	publisher = {{DCW} Industries},
