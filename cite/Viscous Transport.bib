@book{svehla_estimated_1963,
	title = {Estimated Viscosities and Thermal Conductivities of Gases at High Temperatures},
	url = {https://www.osti.gov/biblio/4803072},
	abstract = {Viscosities and thermal conductivities, suitable for heat-transfer calculations, were estimated for about 200 gases in the ground state from 100° to 5000° K and 1-atm pressure. Free radicals were included, but excited states and ions were not. Calculations for the transport coefficients were based upon the Lennard-Jones (12-6) potential for all gases. Intermolecular force constants for this potential were obtained from experimental viscosity data or were estimated when data were not available. The same set of constants was used to calculate both viscosity and conductivity. An Eucken-type correction for exchange between internal and translational energies was made for thermal conductivities of polyatomic gases.},
	pagetotal = {132},
	publisher = {National Aeronautics and Space Administration},
	author = {Svehla, Roger A.},
	date = {1963},
	langid = {english},
	file = {PDF:/Users/speedyturtle/Zotero/storage/GNZAHTML/Svehla - 1963 - Estimated Viscosities and Thermal Conductivities of Gases at High Temperatures.pdf:application/pdf},
}

