@report{gupta_review_1990,
	title = {Review of Reaction Rates and Thermodynamic and Transport Properties for an 11-Species Air Model for Chemical and Thermal Nonequilibrium Calculations to 30000 K.},
	url = {https://ntrl.ntis.gov/NTRL/dashboard/searchResults/titleDetail/N9027064.xhtml},
	abstract = {Reaction rate coefficients and thermodynamic and transport properties are reviewed and supplemented for the 11-species air model which can be used for analyzing flows in chemical and thermal nonequilibrium up to temperatures of 3000 K. Such flows will likely occur around currently planned and future hypersonic vehicles. Guidelines for determining the state of the surrounding environment are provided. Curve fits are given for the various species properties for their efficient computation in flowfield codes. Approximate and more exact formulas are provided for computing the properties of partially ionized air mixtures in a high energy environment. Limitations of the approximate mixing laws are discussed for a mixture of ionized species. An electron number-density correction for the transport properties of the charged species is obtained. This correction has been generally ignored in the literature.},
	number = {N9027064},
	institution = {National Aeronautics and Space Administration, Hampton, {VA}. Langley Research Center.},
	author = {Gupta, R. N. and Yos, J. M. and Thompson, R. A. and Lee, K.},
	urldate = {2026-06-19},
	date = {1990},
	note = {Num Pages: 94},
	keywords = {Computational fluid dynamics, Air, Air flow, Flow distribution, High temperature gases, Ionized gases, Models, Nonequilibrium flow, Nonequilibrium thermodynamics, Reaction kinetics, Thermodynamic properties, Transport properties},
	file = {PDF:/Users/speedyturtle/Zotero/storage/SF8HL4WM/Gupta et al. - 1990 - Review of Reaction Rates and Thermodynamic and Transport Properties for an 11-Species Air Model for.pdf:application/pdf;Snapshot:/Users/speedyturtle/Zotero/storage/9WK9IPAI/N9027064.html:text/html},
}

