	shortjournal = {{SIAM} J. Sci. Comput.},
	publisher = {Society for Industrial and Applied Mathematics},
	author = {Pernice, Michael and Walker, Homer F.},
	urldate = {2026-06-19},
	date = {1998-01},
	file = {Full Text PDF:/Users/speedyturtle/Zotero/storage/8X6E8ZDR/Pernice and Walker - 1998 - NITSOL A Newton Iterative Solver for Nonlinear Systems.pdf:application/pdf},
}

