@article{flyer_role_2016,
	title = {On the role of polynomials in {RBF}-{FD} approximations: I. Interpolation and accuracy},
	volume = {321},
	issn = {0021-9991},
	url = {https://www.sciencedirect.com/science/article/pii/S0021999116301632},
	doi = {10.1016/j.jcp.2016.05.026},
	shorttitle = {On the role of polynomials in {RBF}-{FD} approximations},
	abstract = {Radial basis function-generated finite difference ({RBF}-{FD}) approximations generalize classical grid-based finite differences ({FD}) from lattice-based to scattered node layouts. This greatly increases the geometric flexibility of the discretizations and makes it easier to carry out local refinement in critical areas. Many different types of radial functions have been considered in this {RBF}-{FD} context. In this study, we find that (i) polyharmonic splines ({PHS}) in conjunction with supplementary polynomials provide a very simple way to defeat stagnation (also known as saturation) error and (ii) give particularly good accuracy for the tasks of interpolation and derivative approximations without the hassle of determining a shape parameter. In follow-up studies, we will focus on how to best use these hybrid {RBF} polynomial bases for {FD} approximations in the contexts of solving elliptic and hyperbolic type {PDEs}.},
	pages = {21--38},
	journaltitle = {Journal of Computational Physics},
	shortjournal = {Journal of Computational Physics},
	author = {Flyer, Natasha and Fornberg, Bengt and Bayona, Victor and Barnett, Gregory A.},
	urldate = {2026-06-19},
	date = {2016-09-15},
	keywords = {Derivative approximations, Interpolation, Polyharmonic splines, Polynomials, {RBF}-{FD}},
	file = {ScienceDirect Full Text PDF:/Users/speedyturtle/Zotero/storage/ZCUJNZVK/Flyer et al. - 2016 - On the role of polynomials in RBF-FD approximations I. Interpolation and accuracy.pdf:application/pdf;ScienceDirect Snapshot:/Users/speedyturtle/Zotero/storage/LEQUGAAW/S0021999116301632.html:text/html},
}

@article{bayona_role_2017,
	title = {On the role of polynomials in {RBF}-{FD} approximations: {II}. Numerical solution of elliptic {PDEs}},
	volume = {332},
	issn = {0021-9991},
	url = {https://www.sciencedirect.com/science/article/pii/S0021999116306490},
	doi = {10.1016/j.jcp.2016.12.008},
	shorttitle = {On the role of polynomials in {RBF}-{FD} approximations},
	abstract = {{RBF}-generated finite differences ({RBF}-{FD}) have in the last decade emerged as a very powerful and flexible numerical approach for solving a wide range of {PDEs}. We find in the present study that combining polyharmonic splines ({PHS}) with multivariate polynomials offers an outstanding combination of simplicity, accuracy, and geometric flexibility when solving elliptic equations in irregular (or regular) regions. In particular, the drawbacks on accuracy and stability due to Runge's phenomenon are overcome once the {RBF} stencils exceed a certain size due to an underlying minimization property. Test problems include the classical 2-D driven cavity, and also a 3-D global electric circuit problem with the earth's irregular topography as its bottom boundary. The results we find are fully consistent with previous results for data interpolation.},
	pages = {257--273},
	journaltitle = {Journal of Computational Physics},
	shortjournal = {Journal of Computational Physics},
	author = {Bayona, Victor and Flyer, Natasha and Fornberg, Bengt and Barnett, Gregory A.},
	urldate = {2026-06-19},
	date = {2017-03-01},
	keywords = {Polyharmonic splines, Polynomials, {RBF}-{FD}, Elliptic {PDEs}, Meshless, Runge's phenomenon},
	file = {ScienceDirect Full Text PDF:/Users/speedyturtle/Zotero/storage/BUREWDCY/Bayona et al. - 2017 - On the role of polynomials in RBF-FD approximations II. Numerical solution of elliptic PDEs.pdf:application/pdf;ScienceDirect Snapshot:/Users/speedyturtle/Zotero/storage/5LND6KMB/S0021999116306490.html:text/html},
}

@article{bayona_role_2019,
	title = {On the role of polynomials in {RBF}-{FD} approximations: {III}. Behavior near domain boundaries},
	volume = {380},
	issn = {0021-9991},
	url = {https://www.sciencedirect.com/science/article/pii/S002199911830809X},
	doi = {10.1016/j.jcp.2018.12.013},
	shorttitle = {On the role of polynomials in {RBF}-{FD} approximations},
	abstract = {Radial basis function generated finite difference ({RBF}-{FD}) approximations generalize grid-based regular finite differences to scattered node sets. These become particularly effective when they are based on polyharmonic splines ({PHS}) augmented with multi-variate polynomials ({PHS}+poly). One key feature is that high orders of accuracy can be achieved without having to choose an optimal shape parameter and without having to deal with issues related to numerical ill-conditioning. The strengths of this approach were previously shown to be especially striking for approximations near domain boundaries, where the stencils become highly one-sided. Due to the polynomial Runge phenomenon, regular {FD} approximations of high accuracy will in such cases have very large weights well into the domain. The inclusion of {PHS}-type {RBFs} in the process of generating weights makes it possible to avoid this adverse effect. With that as motivation, this study aims at gaining a better understanding of the behavior of {PHS}+poly generated {RBF}-{FD} approximations near boundaries, illustrating it in 1-D, 2-D and 3-D.},
	pages = {378--399},
	journaltitle = {Journal of Computational Physics},
	shortjournal = {Journal of Computational Physics},
	author = {Bayona, Víctor and Flyer, Natasha and Fornberg, Bengt},
	urldate = {2026-06-19},
	date = {2019-03-01},
	keywords = {{RBF}-{FD}, Runge's phenomenon, Cubic polyharmonic splines, {PHS}, Radial basis functions, {RBF}},
	file = {ScienceDirect Full Text PDF:/Users/speedyturtle/Zotero/storage/QLDT5RVG/Bayona et al. - 2019 - On the role of polynomials in RBF-FD approximations III. Behavior near domain boundaries.pdf:application/pdf;ScienceDirect Snapshot:/Users/speedyturtle/Zotero/storage/2N8X4SKR/S002199911830809X.html:text/html},
}
