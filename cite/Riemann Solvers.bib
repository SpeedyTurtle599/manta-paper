@article{ismail_affordable_2009,
	title = {Affordable, entropy-consistent Euler flux functions {II}: Entropy production at shocks},
	volume = {228},
	issn = {0021-9991},
	url = {https://www.sciencedirect.com/science/article/pii/S0021999109002113},
	doi = {10.1016/j.jcp.2009.04.021},
	shorttitle = {Affordable, entropy-consistent Euler flux functions {II}},
	abstract = {In this paper, an entropy-consistent flux is developed, continuing from the work of the previous paper. To achieve entropy consistency, a second and third-order differential terms are added to the entropy-conservative flux. This new flux function is tested on several one dimensional problems and compared with the original Roe flux. The new flux function exactly preserves the stationary contact discontinuity and does not capture the unphysical rarefaction shock. For steady shock problems, the new flux predicts a slightly more diffused profile whereas for unsteady cases, the captured shock is very similar to those produced by the Roe- flux. The shock stability is also studied in one dimension. Unlike the original Roe flux, the new flux is completely stable which will provide as a candidate to combat multidimensional shock instability, particularly the carbuncle phenomenon.},
	pages = {5410--5436},
	number = {15},
	journaltitle = {Journal of Computational Physics},
	shortjournal = {Journal of Computational Physics},
	author = {Ismail, Farzad and Roe, Philip L.},
	urldate = {2026-06-18},
	date = {2009-08-20},
	keywords = {Entropy conservation, Entropy consistency, Entropy production, Entropy-stability, Shock stability},
	file = {ScienceDirect Full Text PDF:/Users/speedyturtle/Zotero/storage/RNWQVPB7/Ismail and Roe - 2009 - Affordable, entropy-consistent Euler flux functions II Entropy production at shocks.pdf:application/pdf;ScienceDirect Snapshot:/Users/speedyturtle/Zotero/storage/64SEPLMB/S0021999109002113.html:text/html},
}

